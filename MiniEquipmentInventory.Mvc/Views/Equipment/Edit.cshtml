@model EquipmentEditViewModel

@{
    ViewData["Title"] = "Edit Equipment";
}
<div class="page-header">
    <div>
        <h2 class="page-title">Edit Equipment</h2>
    </div>
</div>
<div class="form-layout" style="display: flex; gap: 40px; margin-top: 20px;">
    <form class="form-box"
          asp-controller="Equipment"
          asp-action="Edit"
          method="post"
          style="flex: 1; max-width: 600px; padding: 25px; border: 1px solid #e2e8f0; border-radius: 8px; background-color: white;">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 15px;"></div>

        <input type="hidden" asp-for="EquipId" />
        <input type="hidden" asp-for="RowVersion" />

        <div class="form-group" style="margin-bottom: 20px;">
            <label asp-for="EquipName" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;">Tên thiết bị</label>
            <input asp-for="EquipName"
                   class="form-control"
                   style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box;" />
            <span asp-validation-for="EquipName" class="text-danger" style="display: block; margin-top: 5px; font-size: 0.85rem; color: #e53e3e;"></span>
        </div>

        <div class="form-group" style="margin-bottom: 20px;">
            <label asp-for="EquipCode" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;">SKU</label>
            <input asp-for="EquipCode"
                   class="form-control"
                   style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box;" />
            <span asp-validation-for="EquipCode" class="text-danger" style="display: block; margin-top: 5px; font-size: 0.85rem; color: #e53e3e;"></span>
        </div>

        <div class="form-group" style="margin-bottom: 20px;">
            <label asp-for="EquipCategory" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;">Danh mục thiết bị</label>
            <select asp-for="EquipCategory" 
                    class="form-control" 
                    style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box; background-color: white;">
                <option value="">-- Chọn danh mục --</option>
                <option value="Projection Equipment">Projection Equipment</option>
                <option value="Board Equipment">Board Equipment</option>
                <option value="Audio Equipment">Audio Equipment</option>
                <option value="Furniture">Furniture</option>
            </select>
            <span asp-validation-for="EquipCategory" class="text-danger" style="display: block; margin-top: 5px; font-size: 0.85rem; color: #e53e3e;"></span>
        </div>

        <div class="form-group" style="margin-bottom: 20px;">
            <label asp-for="EquipSupplier" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;">Nhà cung cấp</label>
            <input asp-for="EquipSupplier"
                   class="form-control"
                   style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box;" />
            <span asp-validation-for="EquipSupplier" class="text-danger" style="display: block; margin-top: 5px; font-size: 0.85rem; color: #e53e3e;"></span>
        </div>

        <div class="form-group" style="margin-bottom: 20px;">
            <label asp-for="EquipUnitPrice" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;">Giá bán</label>
            <input asp-for="EquipUnitPrice"
                   class="form-control"
                   style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box;" />
            <span asp-validation-for="EquipUnitPrice" class="text-danger" style="display: block; margin-top: 5px; font-size: 0.85rem; color: #e53e3e;"></span>
        </div>

        <div class="form-group" style="margin-bottom: 20px;">
            <label asp-for="EquipQuantity" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;">Số lượng tồn kho</label>
            <input asp-for="EquipQuantity"
                   class="form-control"
                   style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box;" />
            <span asp-validation-for="EquipQuantity" class="text-danger" style="display: block; margin-top: 5px; font-size: 0.85rem; color: #e53e3e;"></span>
        </div>

        <div class="form-group" style="margin-bottom: 20px;">
            <label asp-for="EquipMinStock" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;">Mức tồn tối thiểu</label>
            <input asp-for="EquipMinStock"
                   type="number"
                   class="form-control"
                   style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box;" />
            <span asp-validation-for="EquipMinStock" class="text-danger" style="display: block; margin-top: 5px; font-size: 0.85rem; color: #e53e3e;"></span>
        </div>

        <div class="form-group" style="margin-bottom: 25px;">
            <label asp-for="Description" style="display: block; font-weight: bold; margin-bottom: 8px; color: #4a5568;">Mô tả</label>
            <textarea asp-for="Description"
                      class="form-control"
                      style="width: 100%; padding: 10px; border: 1px solid #cbd5e0; border-radius: 6px; box-sizing: border-box; height: 100px; resize: vertical;"></textarea>
            <span asp-validation-for="Description" class="text-danger" style="display: block; margin-top: 5px; font-size: 0.85rem; color: #e53e3e;"></span>
        </div>

        <div style="display: flex; gap: 10px;">
            <button class="btn" type="submit" style="background-color: #2b6cb0; color: white; border: none; padding: 10px 24px; border-radius: 6px; font-weight: bold; cursor: pointer;">
                Save
            </button>
            <a class="btn btn-secondary"
               asp-controller="Equipment"
               asp-action="Index"
               style="background-color: #2d3748; color: white; border: none; padding: 10px 24px; border-radius: 6px; font-weight: bold; text-decoration: none; display: inline-block;">
                Back
            </a>
        </div>
    </form>
    
    <div class="info-box" style="flex: 1; max-width: 400px; padding: 25px; border: 1px solid #bee3f8; border-radius: 8px; background-color: #ebf8ff; align-self: flex-start;">
        <h3 style="margin-top: 0; color: #2b6cb0; font-size: 1.25rem;">Lab05 Concepts</h3>
        <p style="color: #2d3748; line-height: 1.6; font-size: 0.95rem;">
            Create/Edit dùng ViewModel và DataAnnotations.<br />
            Không cho user nhập CreatedAt, UpdatedAt, IsDeleted hoặc RowVersion.
        </p>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
