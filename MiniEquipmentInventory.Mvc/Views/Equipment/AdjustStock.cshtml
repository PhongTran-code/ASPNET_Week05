@model EquipmentAdjustStockViewModel
@{
    ViewData["Title"] = "Điều chỉnh số lượng tồn kho";
}

<style>
    .adjust-container {
        max-width: 600px;
        margin: 20px 0;
    }
    .card-info {
        background-color: #f7fafc;
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 20px;
    }
    .form-group {
        margin-bottom: 20px;
    }
    .form-group label {
        display: block;
        font-weight: bold;
        margin-bottom: 8px;
        color: #4a5568;
    }
    .form-control-static {
        padding: 8px 12px;
        background-color: #edf2f7;
        border-radius: 6px;
        color: #2d3748;
        font-size: 15px;
        border: 1px solid #cbd5e0;
    }
    .form-input {
        width: 100%;
        padding: 10px 12px;
        border: 1px solid #cbd5e0;
        border-radius: 6px;
        font-size: 16px;
        box-sizing: border-box;
    }
    .form-input:focus {
        border-color: #dd6b20;
        outline: none;
        box-shadow: 0 0 0 3px rgba(221, 107, 32, 0.15);
    }
    .error-msg {
        color: #e53e3e;
        font-size: 14px;
        margin-top: 6px;
        display: block;
    }
    .concurrency-warning {
        background-color: #fffaf0;
        border: 1px solid #feebc8;
        color: #c05621;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 20px;
    }
    .validation-summary {
        background-color: #fff5f5;
        border: 1px solid #fed7d7;
        color: #c53030;
        border-radius: 8px;
        padding: 16px;
        margin-bottom: 20px;
    }
    .validation-summary ul {
        margin: 8px 0 0 0;
        padding-left: 20px;
    }
    .btn-submit {
        background-color: #dd6b20;
        color: white;
        border: none;
        padding: 10px 24px;
        border-radius: 6px;
        font-weight: bold;
        font-size: 15px;
        cursor: pointer;
        transition: background-color 0.2s ease;
    }
    .btn-submit:hover {
        background-color: #c05621;
    }
    .btn-cancel {
        background-color: #718096;
        color: white;
        border: none;
        padding: 10px 24px;
        border-radius: 6px;
        font-weight: bold;
        font-size: 15px;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        margin-left: 10px;
        text-align: center;
    }
    .btn-cancel:hover {
        background-color: #4a5568;
    }
</style>

<div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <div>
        <h2 class="page-title" style="margin: 0; font-size: 2rem; font-weight: bold; color: #1a202c;">Điều chỉnh tồn kho</h2>
        <p style="margin: 5px 0 0; color: #718096;">Chỉ cập nhật số lượng thiết bị nhanh và kiểm tra xung đột đồng thời.</p>
    </div>
    <a class="btn" asp-controller="Equipment" asp-action="Index" style="background-color: #4a5568; color: white; border: none; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: bold;">Quay lại</a>
</div>

<div class="adjust-container">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="validation-summary">
            <strong>Đã xảy ra lỗi:</strong>
            <div asp-validation-summary="ModelOnly"></div>
        </div>
    }

    @if (ViewBag.LatestQuantity != null)
    {
        <div class="concurrency-warning">
            <strong>⚠️ Cảnh báo xung đột đồng thời:</strong>
            <p style="margin: 8px 0 0;">Giá trị hiện tại trong hệ thống đã được cập nhật thành: <strong>@ViewBag.LatestQuantity</strong> bởi một người dùng khác.</p>
            <p style="margin: 4px 0 0; font-size: 14px;">Bạn có thể điều chỉnh lại số lượng dựa trên thông tin này và nhấn cập nhật lần nữa.</p>
        </div>
    }

    <div class="form-box" style="padding: 24px; border: 1px solid #e2e8f0; border-radius: 8px; background-color: #fff; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05);">
        <form asp-controller="Equipment" asp-action="AdjustStock" method="post">
            @Html.AntiForgeryToken()
            
            <input type="hidden" asp-for="EquipId" />
            <input type="hidden" asp-for="RowVersion" />

            <div class="card-info">
                <div style="display: flex; justify-content: space-between; margin-bottom: 8px;">
                    <span style="font-weight: bold; color: #4a5568;">Thiết bị:</span>
                    <span style="color: #2d3748;">@Model.EquipName</span>
                </div>
                <div style="display: flex; justify-content: space-between;">
                    <span style="font-weight: bold; color: #4a5568;">Mã SKU:</span>
                    <code style="background-color: #edf2f7; padding: 2px 6px; border-radius: 4px; color: #2b6cb0;">@Model.EquipCode</code>
                </div>
            </div>

            <div class="form-group">
                <label asp-for="EquipQuantity"></label>
                <input type="number" asp-for="EquipQuantity" class="form-input" placeholder="Nhập số lượng tồn kho..." min="0" max="100000" />
                <span asp-validation-for="EquipQuantity" class="error-msg"></span>
            </div>

            <div style="margin-top: 30px; display: flex;">
                <button type="submit" class="btn-submit">Cập nhật số lượng</button>
                <a asp-controller="Equipment" asp-action="Index" class="btn-cancel">Hủy bỏ</a>
            </div>
        </form>
    </div>
</div>
