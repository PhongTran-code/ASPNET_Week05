@model List<EquipmentListItemViewModel>
@{
    ViewData["Title"] = "Equipment";
}
<div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <div>
        <h2 class="page-title" style="margin: 0; font-size: 2rem; font-weight: bold; color: #1a202c;">Equipment</h2>
    </div>
    <div style="display: flex; gap: 10px;">
        <a class="btn"
           asp-controller="Equipment"
           asp-action="Search"
           style="background-color: #4a5568; color: white; border: none; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: bold; display: inline-block;">
            Search & Filter
        </a>
        <a class="btn"
           asp-controller="Equipment"
           asp-action="Create"
           style="background-color: #2b6cb0; color: white; border: none; padding: 10px 20px; border-radius: 6px; text-decoration: none; font-weight: bold; display: inline-block;">
            Create New
        </a>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="success-box" style="margin-bottom: 20px; padding: 15px; background-color: #d4edda; color: #155724; border-radius: 6px; border: 1px solid #c3e6cb;">
        @TempData["SuccessMessage"]
    </div>
}

@if (Model.Count == 0)
{
    <p>Chưa có thiết bị nào trong hệ thống.</p>
}
else
{
    <table class="table table-bordered table-striped mt-3" style="width: 100%; border-collapse: collapse; margin-top: 20px; background-color: white;">
        <thead>
            <tr style="border-bottom: 2px solid #ddd;">
                <th style="padding: 12px 10px; text-align: left; width: 8%; color: white; background-color: #1a202c;">ID</th>
                <th style="padding: 12px 10px; text-align: left; color: white; background-color: #1a202c;">Name</th>
                <th style="padding: 12px 10px; text-align: left; width: 15%; color: white; background-color: #1a202c;">Price</th>
                <th style="padding: 12px 10px; text-align: left; width: 10%; color: white; background-color: #1a202c;">Stock</th>
                <th style="padding: 12px 10px; text-align: left; width: 18%; color: white; background-color: #1a202c;">Created At</th>
                <th style="padding: 12px 10px; text-align: left; width: 18%; color: white; background-color: #1a202c;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr style="border-bottom: 1px solid #e2e8f0;">
                    <td style="padding: 12px 10px;">@item.EquipId</td>
                    <td style="padding: 12px 10px;">@item.EquipName</td>
                    <td style="padding: 12px 10px;">@item.PriceText</td>
                    <td style="padding: 12px 10px;">@item.EquipQuantity</td>
                    <td style="padding: 12px 10px;">@item.CreatedAt.ToString("dd/MM/yyyy")</td>
                    <td style="padding: 12px 10px;">
                        <a asp-controller="Equipment" asp-action="Edit" asp-route-id="@item.EquipId" style="text-decoration: none; color: #2b6cb0; margin-right: 10px;">[Edit]</a>
                        <a asp-controller="Equipment" asp-action="Delete" asp-route-id="@item.EquipId" style="text-decoration: none; color: #e63946;">[Delete]</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

<p style="margin-top: 20px; color: #718096; font-size: 0.9rem;">Chỉ hiển thị thiết bị IsDeleted = false. Nút Delete thực hiện xóa mềm.</p>
